# AI Mentor — PRODUCTION environment template.
# Copy to `.env` next to docker-compose.prod.yml and fill in real values.
# NEVER commit the filled-in .env (it is already covered by .gitignore).
#
# Generate strong secrets, e.g.:
#   openssl rand -base64 48        # BETTER_AUTH_SECRET / INTERNAL_API_TOKEN
#   openssl rand -base64 32        # POSTGRES_PASSWORD

# ── Public domain / TLS (Caddy) ───────────────────────────────────────────
APP_DOMAIN=intellector.example.com
TLS_EMAIL=admin@example.com

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_USER=ai_mentor
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ai_mentor

# ── Backend (FastAPI) ─────────────────────────────────────────────────────
# REQUIRED: grants trusted internal super-admin service calls. Must be a strong,
# unique secret — the old public default is no longer accepted.
INTERNAL_API_TOKEN=change-me-strong-random-token
# Comma-separated list of allowed browser origins (your public https URL).
CORS_ALLOW_ORIGINS=https://intellector.example.com
OLLAMA_MODEL=phi3:mini

# Optional pool tuning (defaults preserve original behaviour). Lower these — or
# point DATABASE_URL at PgBouncer — to bound total Postgres connections when many
# tenants are active.
# DB_CONTROL_POOL_SIZE=10
# DB_CONTROL_MAX_OVERFLOW=20
# DB_TENANT_POOL_SIZE=5
# DB_TENANT_MAX_OVERFLOW=10
# TENANT_DB_POOL_MAX=10   # frontend per-tenant pg pool

# Optional memory ceilings (host protection).
# OLLAMA_MEM_LIMIT=5g
# API_MEM_LIMIT=4g

# ── Frontend (Next.js / Better Auth) ──────────────────────────────────────
# Public HTTPS URL of the app (must match APP_DOMAIN).
BETTER_AUTH_URL=https://intellector.example.com
BETTER_AUTH_SECRET=change-me-strong-random-secret
# Google OAuth (leave blank to disable social login).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
